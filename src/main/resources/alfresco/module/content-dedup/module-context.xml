<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Module Spring entry point — import sub-contexts only, never define beans here.
        Load order matters: bootstrap first (dictionary), then services/behaviours.
    -->
    <import resource="classpath:alfresco/module/content-dedup/context/bootstrap-context.xml"/>
    <import resource="classpath:alfresco/module/content-dedup/context/service-context.xml"/>

</beans>
